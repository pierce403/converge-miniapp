{
  "name": "converge-miniapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "assets": "node scripts/generate-assets.mjs",
    "preview": "npm run build && vite preview",
    "deploy": "npm run check && wrangler deploy",
    "deploy:preview": "npm run check && wrangler deploy --env preview",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@farcaster/miniapp-sdk": "0.3.0",
    "@xmtp/browser-sdk": "7.0.0",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "sharp": "0.35.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "jayson": {
      "uuid": "11.1.1"
    }
  }
}
