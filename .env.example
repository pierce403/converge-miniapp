# Local development uses the public XMTP development environment.
VITE_XMTP_ENV=dev

# The pinned SDK's legacy production environment has a built-in endpoint. A
# Gateway hostname is required only for mainnet and the decentralized testnets.
# This value is public browser configuration, never a credential; Gateway
# authentication remains an explicit mainnet release blocker.
# VITE_XMTP_GATEWAY_HOST=gateway.example.com
